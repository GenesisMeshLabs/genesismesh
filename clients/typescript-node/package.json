{
  "name": "@genesis-mesh/node",
  "version": "0.1.0",
  "description": "TypeScript Genesis Mesh peer node (Node.js runtime) with a control API for browser webapps.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "gm-node": "dist/daemon.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "daemon": "tsx src/daemon.ts",
    "verify-genesis": "tsx scripts/verify-genesis.ts",
    "test:canonical": "tsx scripts/test-canonical.ts",
    "webapp": "node scripts/serve-webapp.mjs"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}

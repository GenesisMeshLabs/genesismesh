# Genesis Mesh — example environment file.
#
# Copy to .env and fill in real values for your environment:
#   cp .env.example .env
# .env is gitignored. Do not commit secrets.

# ---------------------------------------------------------------------------
# Azure deployment (Terraform + GitHub Actions OIDC)
# ---------------------------------------------------------------------------
AZURE_CLIENT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=

# SSH access for the NA VM
NA_SSH_PUBLIC_KEY=
NA_ADMIN_CIDR=

# Terraform remote state
TF_STATE_RESOURCE_GROUP=terraform-state-rg
TF_STATE_STORAGE_ACCOUNT=tfstategenesismesh

# GitHub Actions deployment workflow
AZURE_LOCATION=swedencentral

# ---------------------------------------------------------------------------
# Healthchecks.io — external /readyz probe + (later) backup dead-man switch
# ---------------------------------------------------------------------------
# https://healthchecks.io/accounts/profile/  →  API Access
HEALTHCHECKS_API_KEY=
HEALTHCHECKS_READYZ_URL=

# ---------------------------------------------------------------------------
# PyPI publishing — username is always "__token__"; password is the token.
# Real PyPI:  https://pypi.org/manage/account/token/
# TestPyPI:   https://test.pypi.org/manage/account/token/
# ---------------------------------------------------------------------------
PYPI_API_TOKEN=
TESTPYPI_API_TOKEN=

# ---------------------------------------------------------------------------
# LLM provider for examples/agent-network/llm_agent.py
#
# This example uses LiteLLM, which routes by model-prefix to ~100 providers
# without any code changes. To swap provider, just change LLM_MODEL (and
# usually LLM_BASE_URL).
#
#   openai/gpt-4o-mini                          OpenAI
#   openai/<deployment>                         Azure OpenAI v1 endpoint
#                                               (set LLM_BASE_URL to the
#                                               https://<resource>.services.ai.azure.com/openai/v1 endpoint)
#   anthropic/claude-sonnet-4-6                 Anthropic
#   ollama/llama3.1                             Local Ollama (no API key)
#   mistral/mistral-small-latest                Mistral
#   groq/llama-3.1-70b-versatile                Groq
#   together_ai/<model>                         Together
#   openai/<model>                              Any OpenAI-compatible endpoint
#                                               (vLLM, LM Studio, …) via LLM_BASE_URL
# ---------------------------------------------------------------------------
LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_SYSTEM_PROMPT="You are an agent on a Genesis Mesh network. Be concise and factual."
